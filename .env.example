# ERDB Configuration Example
# Copy this file to .env and adjust the values as needed.

# --- Global Settings ---
# NODE_ENV=production
# ERDB_HTTP_PORT=3000
# Bind the standalone Next server inside Docker. This is internal only and is not your public domain.
# ERDB_BIND_HOST=0.0.0.0

# --- Proxy / Security ---
# Trust x-forwarded-host and x-forwarded-proto when behind a reverse proxy (e.g. Traefik, Caddy, nginx).
# ERDB_TRUST_PROXY_HEADERS=true

# --- Release Notifications ---
# GitHub Actions does not read your local .env file.
# Discord release posts use the repository Actions secret WEBHOOK_URL instead.
# WEBHOOK_URL=

# Comma-separated CORS allowlist for proxy routes.
# Empty = *.
# ERDB_PROXY_ALLOWED_ORIGINS=*

# Optional dedicated key for the fixed README live preview gallery.
# This is only used by /preview/{slug} and does not replace BYOK for normal requests.
# Local release/doc scripts load these automatically from .env or .env.local.
# Keep PREVIEW_INTERNAL_ORIGIN on loopback when the container bind host is 0.0.0.0.
# PREVIEW_INTERNAL_ORIGIN=http://127.0.0.1:3000
# ERDB_README_PREVIEW_TMDB_KEY=
# ERDB_README_PREVIEW_MDBLIST_KEY=
# ERDB_TMDB_API_BASE_URL=https://api.themoviedb.org/3
# ERDB_ANILIST_GRAPHQL_URL=https://graphql.anilist.co
# ERDB_ANIME_MAPPING_BASE_URL=https://animemapping.stremio.dpdns.org
# ERDB_KITSU_API_BASE_URL=https://kitsu.io/api/edge
# ERDB_MAL_CLIENT_ID=
# ERDB_TRAKT_CLIENT_ID=
# ERDB_MAL_API_BASE_URL=https://api.myanimelist.net/v2
# ERDB_JIKAN_API_BASE_URL=https://api.jikan.moe/v4
# ERDB_TRAKT_API_BASE_URL=https://api.trakt.tv

# --- Cache TTL Settings (all values in milliseconds) ---
# Ratings cache per provider
# ERDB_TMDB_CACHE_TTL_MS=259200000           # Default: 3 days  (min: 10 min, max: 30 days)
# ERDB_MDBLIST_CACHE_TTL_MS=259200000        # Default: 3 days  (min: 10 min, max: 30 days)
# ERDB_KITSU_CACHE_TTL_MS=259200000          # Default: 3 days  (min: 10 min, max: 30 days)
# ERDB_TORRENTIO_CACHE_TTL_MS=21600000       # Default: 6 hours (min: 10 min, max: 7 days)
# ERDB_PROVIDER_ICON_CACHE_TTL_MS=604800000  # Default: 7 days  (min: 1 hour, max: 30 days)
# ERDB_IMDB_DATASET_CACHE_TTL_MS=604800000   # Default: 7 days  (min: 1 hour, max: 365 days)

# "Old Media" logic: extend cache for titles older than AGE_DAYS
# ERDB_MDBLIST_OLD_MOVIE_CACHE_TTL_MS=604800000  # Default: 7 days  (min: 1 hour, max: 30 days)
# ERDB_MDBLIST_OLD_MOVIE_AGE_DAYS=365            # Default: 365     (min: 30, max: 3650)

# MDBList rate-limit cooldown (pause fetching after hitting rate limit)
# ERDB_MDBLIST_RATE_LIMIT_COOLDOWN_MS=86400000   # Default: 1 day   (min: 30 sec, max: 7 days)

# --- Torrentio Stream Badges ---
# Custom Torrentio base URL (for self-hosted instances)
# ERDB_TORRENTIO_BASE_URL=https://torrentio.strem.fun

# --- IMDb Local Datasets ---
# ERDB_IMDB_DATASET_AUTO_DOWNLOAD=true
# ERDB_IMDB_DATASET_AUTO_IMPORT=true
# ERDB_IMDB_RATINGS_DATASET_PATH=./data/imdb/title.ratings.tsv.gz
# ERDB_IMDB_DATASET_REFRESH_MS=259200000
# ERDB_IMDB_DATASET_CHECK_INTERVAL_MS=900000
# ERDB_IMDB_DATASET_BASE_URL=https://datasets.imdbws.com
# ERDB_IMDB_RATINGS_DATASET_URL=https://datasets.imdbws.com/title.ratings.tsv.gz
# ERDB_IMDB_DATASET_IMPORT_BATCH=5000
# ERDB_IMDB_DATASET_IMPORT_PROGRESS=0
# ERDB_IMDB_DATASET_LOG=false

# --- Sharp Rendering Performance (advanced) ---
# Tune based on available CPU/RAM. Leaving unset uses Sharp defaults.
# ERDB_SHARP_CONCURRENCY=4          # Max Sharp threads. Higher = more parallelism, more CPU.
# ERDB_SHARP_CACHE_MEMORY_MB=512    # Memory (MB) for Sharp internal cache. Higher = faster repeats, more RAM.
# ERDB_SHARP_CACHE_ITEMS=2000       # Max cached items in Sharp. Higher = more cache hits.
# ERDB_SHARP_CACHE_FILES=20000      # Max cached files/handles in Sharp. Higher = better IO reuse.

# Preset suggestions (pick one block and uncomment):
# --- Small (1-2 vCPU, 1-2 GB RAM) ---
# ERDB_SHARP_CONCURRENCY=2
# ERDB_SHARP_CACHE_MEMORY_MB=128
# ERDB_SHARP_CACHE_ITEMS=512
# ERDB_SHARP_CACHE_FILES=2000

# --- Medium (2-4 vCPU, 4-8 GB RAM) ---
# ERDB_SHARP_CONCURRENCY=4
# ERDB_SHARP_CACHE_MEMORY_MB=512
# ERDB_SHARP_CACHE_ITEMS=2000
# ERDB_SHARP_CACHE_FILES=20000

# --- Large (8+ vCPU, 16+ GB RAM) ---
# ERDB_SHARP_CONCURRENCY=8
# ERDB_SHARP_CACHE_MEMORY_MB=1024
# ERDB_SHARP_CACHE_ITEMS=4000
# ERDB_SHARP_CACHE_FILES=50000
